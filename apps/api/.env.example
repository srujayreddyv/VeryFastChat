# API server
API_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
CREATE_ROOM_RATE_LIMIT=10
JOIN_RATE_LIMIT=30
SEND_MESSAGE_RATE_LIMIT=60
RATE_LIMIT_WINDOW_SECONDS=60

# Supabase (required)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Session cookie signing (required; use a long random string)
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Metrics (optional; when set, GET /metrics requires X-Metrics-Secret header)
# METRICS_SECRET=

# Upstash Redis (optional; when set, rate limiting uses Redis instead of in-memory)
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Share links (set to your frontend URL in production)
# WEB_APP_URL=http://localhost:3000

# CORS (comma-separated; set to your frontend URL in production)
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000
